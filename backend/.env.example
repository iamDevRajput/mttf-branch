PORT=8000
NODE_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/MTTF
JWT_SECRET=replace-with-a-long-random-secret

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Cashfree PG
CASHFREE_APP_ID=replace-with-cashfree-app-id
CASHFREE_SECRET_KEY=replace-with-cashfree-secret-key
CASHFREE_ENV=sandbox
CASHFREE_API_VERSION=2023-08-01

# Browser return URL and public webhook URL registered with Cashfree.
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
CASHFREE_WEBHOOK_URL=https://your-public-api.example.com/api/payments/webhook

# Optional email delivery for successful verified memberships.
EMAIL_USER=your-smtp-or-gmail-user
EMAIL_PASS=your-smtp-or-gmail-app-password
EMAIL_FROM=MTTF <no-reply@example.com>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
